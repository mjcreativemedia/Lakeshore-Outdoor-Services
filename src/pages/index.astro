---
import Base from "../layouts/Base.astro";
import SEO from "../components/SEO.astro";
import JsonLd from "../components/JsonLd.astro";
import { BUSINESS, phone_display, phone_e164 } from "../data/business";

const title = `${BUSINESS.name} | Chicago lawn care and yard cleanup`;
const description =
  "Chicago lawn care and yard cleanup crews serving Hyde Park, South Shore, Bronzeville, Roseland, Pullman, Lakeview, Lincoln Park, Evanston, and nearby neighborhoods.";
const canonical = new URL(Astro.url.pathname, BUSINESS.site).toString();
const { address, areasServed } = BUSINESS;
const phoneDisplay = phone_display;
const businessAddress = {
  "@type": "PostalAddress",
  addressLocality: address.city,
  addressRegion: address.region,
  addressCountry: address.country,
};

const schema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "ServiceAreaBusiness"],
  "@id": `${BUSINESS.site}/#business`,
  name: BUSINESS.name,
  description,
  url: canonical,
  telephone: phone_e164,
  email: BUSINESS.email,
  address: businessAddress,
  areaServed: areasServed,
  sameAs: [],
};

const displayAreas = areasServed;
---
<Base title={title}>
  <SEO title={title} description={description} canonical={canonical} type="website" />
  <JsonLd schema={schema} />
  <section class="hero">
    <div class="hero-content">
      <p class="eyebrow">Chicago outdoor services</p>
      <h1>Lawn care and yard cleanup for neighborhood properties</h1>
      <p>
        {BUSINESS.name} helps homeowners, landlords, churches, and small properties keep grass cut, weeds knocked down, and
        yards cleaned up across Chicago. We focus first on lawn care and yard cleanup, then support simple branch trimming,
        planting, mulch, and winter snow removal when the season changes.
      </p>
      <div class="actions">
        <a class="primary" href="/contact/">Request a quote</a>
        <a class="secondary" href={`tel:${phone_e164}`}>Call {phoneDisplay}</a>
      </div>
      <div class="quick-links">
        <a href="/services/lawn-care/">Lawn care</a>
        <a href="/services/yard-cleanup/">Yard cleanup</a>
        <a href="/services/branch-trimming/">Branch trimming</a>
        <a href="/services/planting-mulch/">Planting and mulch</a>
        <a href="/services/snow-removal/">Seasonal snow removal</a>
        <a href="/locations/">View service areas</a>
      </div>
    </div>
    <div class="hero-media">
      <div class="photo-placeholder">
        <span>Before / after photo coming soon</span>
        <strong>Real yard cleanup and crew photos will go here.</strong>
      </div>
    </div>
  </section>
  <section class="services">
    <h2>Start with the work people need most</h2>
    <p>
      The first offer is simple: keep the grass and yard under control. From there, we can trim light branches, freshen beds with
      mulch, handle basic planting, and keep winter access clear when snow season returns.
    </p>
    <ul class="service-grid">
      <li>
        <strong>Primary</strong>
        <span>Lawn mowing, weed cleanup, edging, leaf pickup, bagging, and general yard cleanup.</span>
      </li>
      <li>
        <strong>Secondary</strong>
        <span>Branch trimming, bush shaping, garden bed cleanup, basic planting, and mulch spreading.</span>
      </li>
      <li>
        <strong>Seasonal</strong>
        <span>Snow removal, sidewalk shoveling, salting, and emergency winter access support.</span>
      </li>
    </ul>
  </section>
  <section class="gallery-ready">
    <div>
      <h2>Built for real proof</h2>
      <p>
        This section is ready for actual crew photos and before/after jobs from Chicago blocks. No stock replacements: the site
        should show the people, properties, tools, and cleanup results customers are really hiring.
      </p>
    </div>
    <ul>
      <li>Before: overgrown grass or weeds</li>
      <li>After: clean lawn and bagged debris</li>
      <li>Crew: real faces and work photos</li>
    </ul>
  </section>
  <section class="areas">
    <h2>Service-area coverage</h2>
    <p>
      We operate without a public storefront and bring mobile crews to each neighborhood we serve. Many existing area pages focus
      on snow removal for search traffic, but these same routes support lawn care, yard cleanup, and seasonal outdoor work.
    </p>
    <ul>
      {displayAreas.map((area) => {
        const slug = area.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "");
        const hasPage = [
          "chicago",
          "hyde-park",
          "lakeview",
          "lincoln-park",
          "evanston",
        ].includes(slug);
        const href = hasPage ? `/locations/snow-removal-${slug}/` : "/locations/";
        return (
          <li>
            <a href={href}>{area}</a>
          </li>
        );
      })}
    </ul>
    <p class="view-more">
      Looking for another neighborhood? See the full list on our <a href="/locations/">locations page</a>.
    </p>
  </section>
</Base>

<style>
  .hero {
    margin: 0 auto;
    max-width: 1100px;
    padding: 4rem 1.5rem 3rem;
    display: grid;
    gap: 2.5rem;
  }

  .hero-content {
    display: grid;
    gap: 1.5rem;
    text-align: center;
  }

  .hero-content .eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.875rem;
    font-weight: 700;
    color: #475569;
  }

  .hero-content h1 {
    font-size: clamp(2.5rem, 5vw, 3.25rem);
    margin: 0;
  }

  .hero-content p {
    font-size: 1.2rem;
    line-height: 1.7;
    color: #1f2937;
  }

  .hero-media {
    width: min(100%, 520px);
    margin: 0 auto;
    border-radius: 1rem;
    box-shadow: 0 20px 45px rgba(15, 23, 42, 0.12);
  }

  .hero-media {
    aspect-ratio: 16 / 11;
    background: #e2e8f0;
    border: 2px dashed #94a3b8;
    display: grid;
    place-items: center;
    overflow: hidden;
    position: relative;
  }

  .hero-media::after {
    content: none;
  }

  .photo-placeholder {
    padding: 2rem;
    display: grid;
    gap: 0.75rem;
    text-align: center;
    color: #334155;
  }

  .photo-placeholder span {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8rem;
    font-weight: 700;
  }

  .photo-placeholder strong {
    font-size: 1.25rem;
    color: #0f172a;
  }

  .actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .primary,
  .secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 1.75rem;
    border-radius: 999px;
    font-weight: 600;
    text-decoration: none;
  }

  .primary {
    background: #2563eb;
    color: #fff;
  }

  .secondary {
    border: 2px solid #2563eb;
    color: #1d4ed8;
    background: transparent;
  }

  .primary:hover,
  .primary:focus {
    background: #1d4ed8;
  }

  .secondary:hover,
  .secondary:focus {
    border-color: #1d4ed8;
    color: #1e3a8a;
  }

  .quick-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  .quick-links a {
    background: #e2e8f0;
    padding: 0.5rem 0.9rem;
    border-radius: 999px;
    font-weight: 600;
    text-decoration: none;
    color: #0f172a;
  }

  .quick-links a:hover,
  .quick-links a:focus {
    background: #cbd5f5;
  }

  .services,
  .gallery-ready,
  .areas {
    margin: 0 auto;
    max-width: 720px;
    padding: 2.5rem 1.5rem;
    display: grid;
    gap: 1.25rem;
  }

  .services ul,
  .gallery-ready ul,
  .areas ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }

  .service-grid li,
  .gallery-ready li {
    background: #e2e8f0;
    border-radius: 0.75rem;
    padding: 1rem;
    display: grid;
    gap: 0.35rem;
  }

  .service-grid strong {
    color: #1d4ed8;
  }

  .gallery-ready {
    max-width: 960px;
    grid-template-columns: minmax(0, 1.2fr) minmax(260px, 0.8fr);
    align-items: start;
  }

  .areas ul {
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  }

  .areas a {
    display: inline-block;
    background: #e2e8f0;
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    font-weight: 600;
    text-align: center;
    text-decoration: none;
    color: #0f172a;
  }

  .areas a:hover,
  .areas a:focus {
    background: #cbd5f5;
  }

  .view-more {
    text-align: center;
    margin: 0;
  }

  @media (min-width: 960px) {
    .hero {
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
      align-items: center;
    }

    .hero-content {
      text-align: left;
    }

    .actions,
    .quick-links {
      justify-content: flex-start;
    }

    .hero-media {
      margin: 0;
      justify-self: center;
    }
  }

  @media (max-width: 760px) {
    .gallery-ready {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .hero-content p {
      font-size: 1.05rem;
    }
  }
</style>
